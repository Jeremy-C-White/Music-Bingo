{
  "description": "Music Bingo game state and claims",
  "collections": [
    {
      "collectionName": "games",
      "documentId": "current",
      "fields": [
        { "name": "sessionId", "type": "string" },
        { "name": "started", "type": "boolean" },
        { "name": "nowPlaying", "type": "string", "nullable": true },
        { "name": "history", "type": "array", "items": { "type": "string" } },
        { "name": "visualizerAudioActive", "type": "boolean" },
        { "name": "updatedAt", "type": "timestamp" }
      ],
      "subcollections": [
        {
          "collectionName": "claims",
          "fields": [
            { "name": "timestamp", "type": "number" },
            { "name": "playerName", "type": "string" },
            { "name": "sessionId", "type": "string" },
            { "name": "songs", "type": "array", "items": { "type": "string" } },
            { "name": "selected", "type": "array", "items": { "type": "boolean" } },
            { "name": "status", "type": "string" },
            { "name": "reason", "type": "string", "nullable": true },
            { "name": "winningLines", "type": "array", "items": { "type": "object" }, "nullable": true },
            { "name": "historyCountAtClaim", "type": "number" },
            { "name": "lastCalledAtClaim", "type": "string", "nullable": true },
            { "name": "position", "type": "number", "nullable": true }
          ]
        }
      ]
    }
  ]
}
