rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/current {
      // Allow anyone to read the game state. 
      // In a real app, caller would be auth'd, but here we'll let anyone write for simplicity,
      // or we can just allow read/write to all for this specific document since it's a game demo.
      allow read, write: if true;
      
      match /claims/{claimId} {
        allow read, write: if true;
      }
    }
  }
}
